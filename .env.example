# ── Hovercode API ─────────────────────────────────────────────
HOVERCODE_WORKSPACE_ID=your_workspace_id
HOVERCODE_API_KEY=your_api_key
HOVERCODE_BASE_URL=https://hovercode.com/api/v2

# ── Database (used by app and Prisma) ─────────────────────────
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@postgres:5432/DB_NAME

# ── PostgreSQL container ───────────────────────────────────────
DB_NAME=qr_code_gen
DB_USER=main
DB_PASSWORD=your_password
